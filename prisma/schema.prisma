generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String     @id @default(cuid())
  name             String?
  email            String     @unique
  passwordHash     String
  createdAt        DateTime   @default(now())
  resetToken       String?
  resetTokenExpiry DateTime?
  bookmarks        Bookmark[]
  topics           Topic[]
}

model Topic {
  id        String   @id @default(cuid())
  userId    String?
  query     String
  slug      String   @unique
  mode      String
  status    String   @default("PENDING")
  createdAt DateTime @default(now())
  nodes     Node[]
  shares    Share[]
  user      User?    @relation(fields: [userId], references: [id])
}

model Node {
  id         String        @id @default(cuid())
  topicId    String
  parentId   String?
  title      String
  depth      Int
  orderIndex Int
  createdAt  DateTime      @default(now())
  bookmarks  Bookmark[]
  parent     Node?         @relation("NodeToNode", fields: [parentId], references: [id])
  children   Node[]        @relation("NodeToNode")
  topic      Topic         @relation(fields: [topicId], references: [id])
  contents   NodeContent[]
}

model NodeContent {
  id             String   @id @default(cuid())
  nodeId         String
  mode           String
  summary        String
  contentMd      String?
  imagePrompt    String?
  flowchart      String?
  keyPoints      String
  examples       String
  misconceptions String?
  faq            String?
  nextConcepts   String?
  createdAt      DateTime @default(now())
  quizData       String?
  visualGrid     String?
  node           Node     @relation(fields: [nodeId], references: [id])
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  nodeId    String
  createdAt DateTime @default(now())
  node      Node     @relation(fields: [nodeId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([userId, nodeId])
}

model Share {
  id        String   @id @default(cuid())
  topicId   String
  shareId   String   @unique
  isPublic  Boolean  @default(true)
  createdAt DateTime @default(now())
  topic     Topic    @relation(fields: [topicId], references: [id])
}
